PORT=5000
MONGO_URI=mongodb://localhost:27017/skillsync
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRE=7d
NODE_ENV=development

# Gmail Setup (for OTP emails)
# Step 1: Go to myaccount.google.com > Security > 2-Step Verification > App Passwords
# Step 2: Create App Password for "Mail"
# Step 3: Paste the 16-character App Password below (no spaces)
GMAIL_USER=youremail@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Optional: GitHub token for higher API rate limits
# GITHUB_TOKEN=ghp_your_token_here
